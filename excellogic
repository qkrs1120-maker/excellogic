function getSolved(){try{return JSON.parse(localStorage.getItem('wl_solved')||'{}');}catch{return {};}}
function markSolved(l,i){const s=getSolved();s[l+'_'+i]=true;localStorage.setItem('wl_solved',JSON.stringify(s));}

